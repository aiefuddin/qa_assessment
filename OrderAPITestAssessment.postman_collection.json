	"item": [
		{
			"name": "TC01 - Create Order Success",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", () => {\r",
							"    pm.response.to.have.status(200);\r",
							"});\r",
							"\r",
							"const body = pm.response.json();\r",
							"\r",
							"pm.test(\"store_id is correct\", () => {\r",
							"    pm.expect(body.json.store_id).to.eql(1);\r",
							"});\r",
							"\r",
							"pm.test(\"quantity is correct\", () => {\r",
							"    pm.expect(body.json.items[0].quantity).to.eql(2);\r",
							"});\r",
							"\r",
							"pm.test(\"size is Large\", () => {\r",
							"    pm.expect(body.json.items[0].customizations.size).to.eql(\"Large\");\r",
							"});\r",
							"\r",
							"pm.test(\"milk is Oat\", () => {\r",
							"    pm.expect(body.json.items[0].customizations.milk).to.eql(\"Oat\");\r",
							"});"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer valid-token",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\r\n  \"store_id\": 1,\r\n  \"items\": [\r\n    {\r\n      \"product_id\": 101,\r\n      \"quantity\": 2,\r\n      \"customizations\": {\r\n        \"size\": \"Large\",\r\n        \"milk\": \"Oat\"\r\n      }\r\n    }\r\n  ],\r\n  \"payment_method_id\": 1\r\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "https://postman-echo.com/post",
					"protocol": "https",
					"host": [
						"postman-echo",
						"com"
					],
					"path": [
						"post"
					]
				}
			},
			"response": []
		},
